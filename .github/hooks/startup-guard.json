{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/init-startup-marker.mjs",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/enforce-startup-marker.mjs",
        "timeout": 10
      }
    ]
  }
}